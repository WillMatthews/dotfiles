# Files in this repo that should NOT be symlinked into $HOME.
# Format: one Perl regex per line, matched against the path relative to the package dir.
README\.md
FUTURE\.md
LICENSE
\.installed
\.gitignore
\.gitmodules
\.git
\.stow-local-ignore
\.scripts/readme\.md
\.scripts/bootstrap-readme
# Machine-local Claude permissions — never stowed.
\.claude/settings\.local\.json
# Per-host docs (symlinked manually into ~/Documents/, not into $HOME root).
^machines
# Firefox profile config — lives under ~/snap/firefox/.../<profile-id>/,
# path has a random suffix per profile so symlinks are set up manually.
^firefox
