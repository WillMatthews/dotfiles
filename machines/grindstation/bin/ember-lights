#!/usr/bin/env bash
# Set keyboard + front light bar to William's matched "ember" scheme (his favourite).
# The two panels render colour differently, so the visually-matching RGBs differ.
# Both reset on reboot; this runs at sway startup (see ~/.config/sway/config).
# The light-bar part needs the 99-lightbar.rules udev rule to work without sudo.
set -u
BIN="$HOME/.local/bin"
"$BIN/ite8291r3-ctl" monocolor --rgb 255,145,40 -b 50   # keyboard  (ITE 8291)
"$BIN/lightbar" color 255 95 55                          # light bar (ITE 8233)
