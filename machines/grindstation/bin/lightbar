#!/usr/bin/env python3
"""Control the Medion Erazer Beast 16 X1 front 'Beast' light bar (ITE 8233, 048d:7001).

Protocol (confirmed 2026-05-27): 8-byte HID feature reports, report-id 0, to interface 1
via control SET_REPORT, exactly like the ITE 8291 keyboard sibling.
  set palette slot N (1..7):  [0x14, 0x00, N, R, G, B, 0, 0]
  apply mode:                 [0x08, 0x22, MODE, SPEED, BRIGHT(0..100), 0x01, DIR, 0]
      MODE 0x01=static  0x02=breathing  0x03=wave  0x04=bounce  0x05=marquee  0x06=scan
      (0x11 flash and >0x06 do nothing on this chassis)
  off sequence:               0x12.. / 0x08 05.. / 0x08 01.. / 0x1A ....01
Motion modes cycle palette slots 1..7 — paint them a rainbow for a scrolling rainbow.
Access: needs write access to the 048d:7001 USB node (libusb detaches hid-generic from
interface 1, then reattaches). Install 99-lightbar.rules (MODE=0666) for rootless use,
otherwise run with sudo.

Usage:
  sudo lightbar color R G B [-b 0..100]
  sudo lightbar off
  sudo lightbar effect {breathing,wave,bounce,marquee,scan} [-s SPEED] [-b BRIGHT] [-c R G B] [-d 0|1|2]
  sudo lightbar rainbow [{wave,marquee,scan,bounce}] [-s SPEED] [-b BRIGHT]   # default: wave
  sudo lightbar demo
  sudo lightbar raw "08 22 03 05 32 01 00 00"
"""
import sys, time, argparse
import usb.core, usb.util

VID, PID, IFACE, SET_REPORT = 0x048D, 0x7001, 1, 0x09
RT_OUT = usb.util.build_request_type(usb.util.CTRL_OUT, usb.util.CTRL_TYPE_CLASS, usb.util.CTRL_RECIPIENT_INTERFACE)

MODES = {"static": 0x01, "breathing": 0x02, "wave": 0x03, "bounce": 0x04, "marquee": 0x05, "scan": 0x06}
RAINBOW = [(255, 0, 0), (255, 80, 0), (255, 200, 0), (0, 255, 0), (0, 200, 255), (0, 0, 255), (180, 0, 255)]


def _clamp(v, hi=255):
    return max(0, min(hi, int(v)))


class Lightbar:
    def __init__(self):
        self.dev = usb.core.find(idVendor=VID, idProduct=PID)
        if self.dev is None:
            sys.exit("ITE 8233 (048d:7001) not found")
        self._detached = False
        try:
            if self.dev.is_kernel_driver_active(IFACE):
                self.dev.detach_kernel_driver(IFACE)
                self._detached = True
        except (usb.core.USBError, NotImplementedError):
            pass

    def _send(self, payload):
        buf = bytes(list(payload) + [0] * (8 - len(payload)))
        self.dev.ctrl_transfer(RT_OUT, SET_REPORT, 0x0300, IFACE, buf)
        time.sleep(0.01)

    def set_palette(self, colors):
        for i, (r, g, b) in enumerate(colors[:7], start=1):
            self._send([0x14, 0x00, i, _clamp(r), _clamp(g), _clamp(b), 0x00, 0x00])

    def _apply(self, mode, speed=5, brightness=100, direction=0):
        self._send([0x08, 0x22, mode, _clamp(speed, 10), _clamp(brightness, 100), 0x01, _clamp(direction, 2), 0x00])

    def color(self, r, g, b, brightness=100):
        self.set_palette([(r, g, b)])
        self._apply(MODES["static"], brightness=brightness)

    def effect(self, name, speed=5, brightness=100, color=None, direction=0):
        palette = RAINBOW if color is None else [color] * 7
        self.set_palette(palette)
        self._apply(MODES[name], speed=speed, brightness=brightness, direction=direction)

    def off(self):
        for p in ([0x12, 0x00, 0x03], [0x08, 0x05], [0x08, 0x01, 0x00], [0x1A, 0x00, 0x00, 0, 0, 0, 0, 0x01]):
            self._send(p)

    def raw(self, hexstr):
        self._send([int(x, 16) for x in hexstr.split()])

    def close(self):
        if self._detached:
            try:
                self.dev.attach_kernel_driver(IFACE)
            except usb.core.USBError:
                pass


EPILOG = """\
examples:
  lightbar color 255 95 55              solid warm-ember (Will's favourite bar colour)
  lightbar color 0 0 255 -b 40          solid blue at brightness 40
  lightbar rainbow                      scrolling rainbow (wave)
  lightbar rainbow marquee -s 8         faster rainbow, marquee style
  lightbar effect breathing -c 255 95 55   breathing ember
  lightbar effect scan -c 0 180 255     blue single-segment scan
  lightbar off                          turn the bar off
  lightbar demo                         showcase every colour and effect
  lightbar raw "08 22 03 05 32 01 00 00"   send a raw 8-byte feature report

modes (for `effect`): breathing wave bounce marquee scan
  wave & marquee cycle palette slots 1-7 (rainbow); breathing/scan/bounce are single-colour.

access: needs write access to the 048d:7001 USB node. Install the udev rule
  99-lightbar.rules (MODE=0666) for rootless use, otherwise run with sudo.
docs: ~/Documents/LIGHT-BAR.md
"""


def main():
    ap = argparse.ArgumentParser(
        prog="lightbar",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description="Control the Medion Erazer Beast 16 X1 front 'Beast' light bar (ITE 8233, 048d:7001).",
        epilog=EPILOG,
    )
    sub = ap.add_subparsers(dest="cmd", required=True, metavar="<command>")

    c = sub.add_parser("color", help="set a solid colour", description="Set the bar to a solid RGB colour.")
    c.add_argument("r", type=int, help="red 0-255")
    c.add_argument("g", type=int, help="green 0-255")
    c.add_argument("b", type=int, help="blue 0-255")
    c.add_argument("-b", "--brightness", type=int, default=100, metavar="0-100", help="brightness percent (default 100)")

    e = sub.add_parser("effect", help="run an animated effect",
                       description="Run an animated effect. wave/marquee cycle the rainbow palette; "
                                   "breathing/scan/bounce are single-colour (slot 1, or --color).")
    e.add_argument("name", choices=[m for m in MODES if m != "static"], help="breathing | wave | bounce | marquee | scan")
    e.add_argument("-s", "--speed", type=int, default=5, metavar="1-10", help="animation speed (default 5)")
    e.add_argument("-b", "--brightness", type=int, default=100, metavar="0-100", help="brightness percent (default 100)")
    e.add_argument("-c", "--color", type=int, nargs=3, metavar=("R", "G", "B"), default=None,
                   help="single colour for breathing/scan/bounce (default: rainbow palette)")
    e.add_argument("-d", "--direction", type=int, default=0, metavar="0|1|2", help="scroll direction (default 0)")

    rb = sub.add_parser("rainbow", help="scrolling rainbow", description="Paint a rainbow across slots 1-7 and scroll it.")
    rb.add_argument("name", nargs="?", choices=["wave", "marquee"], default="wave", help="scroll style (default wave)")
    rb.add_argument("-s", "--speed", type=int, default=5, metavar="1-10", help="animation speed (default 5)")
    rb.add_argument("-b", "--brightness", type=int, default=100, metavar="0-100", help="brightness percent (default 100)")

    sub.add_parser("off", help="turn the bar off", description="Turn the light bar off.")
    sub.add_parser("demo", help="showcase colours + effects", description="Cycle through colours, a brightness ramp, and every effect.")

    r = sub.add_parser("raw", help="send a raw 8-byte packet",
                       description="Send an arbitrary 8-byte feature report (space-separated hex) for experiments.")
    r.add_argument("bytes", metavar='"HH HH ..."', help='8 hex bytes, e.g. "08 22 03 05 32 01 00 00"')

    a = ap.parse_args()

    lb = Lightbar()
    try:
        if a.cmd == "color":
            lb.color(a.r, a.g, a.b, a.brightness); print(f"set {a.r},{a.g},{a.b} @ {a.brightness}%")
        elif a.cmd == "effect":
            lb.effect(a.name, a.speed, a.brightness, tuple(a.color) if a.color else None, a.direction)
            print(f"effect {a.name} speed={a.speed} br={a.brightness} color={a.color or 'rainbow'}")
        elif a.cmd == "rainbow":
            lb.effect(a.name, a.speed, a.brightness, None); print(f"rainbow ({a.name}) speed={a.speed} br={a.brightness}")
        elif a.cmd == "off":
            lb.off(); print("off")
        elif a.cmd == "raw":
            lb.raw(a.bytes); print("sent")
        elif a.cmd == "demo":
            for name, rgb in [("RED", (255, 0, 0)), ("GREEN", (0, 255, 0)), ("BLUE", (0, 0, 255)),
                              ("WHITE", (255, 255, 255)), ("GOLDEN-YELLOW", (255, 170, 0))]:
                print(f"  static {name}"); lb.color(*rgb); time.sleep(1.3)
            print("  brightness ramp (golden-yellow 100 -> 0)")
            for br in (100, 60, 30, 10, 0):
                lb.color(255, 170, 0, br); time.sleep(0.6)
            # wave/marquee cycle the rainbow palette; breathing/scan/bounce are single-colour (slot 1)
            for name, col in [("breathing", (255, 170, 0)), ("wave", None), ("marquee", None),
                              ("scan", (0, 180, 255)), ("bounce", (0, 255, 80))]:
                print(f"  effect {name} ({'rainbow' if col is None else col})"); lb.effect(name, color=col); time.sleep(3)
            print("  OFF"); lb.off(); time.sleep(1.3)
            print("  final: scrolling rainbow (wave)"); lb.effect("wave")
            print("demo done")
    finally:
        lb.close()


if __name__ == "__main__":
    main()
