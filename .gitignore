# Stow-managed dotfiles. New files are tracked by default — list only what
# should NOT make it into git. Stow's "tracked but don't symlink" list is in
# .stow-local-ignore, which is separate.

# Editor / OS cruft
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Secrets / auth — never commit
.tokens
.config/gh/hosts.yml
.claude/settings.local.json
# Work-only shell helpers (Antare). Lives in ~/.config/antare/, sourced from
# .bashrc and .zshrc. Kept out of the repo to preserve the work/personal split.
.config/antare/

# Script-local runtime data (not for the repo)
.scripts/vnc-home
.scripts/tellData

# App-generated dirs that'd land here if you copied a whole config in.
# Use /* + negation so hand-written themes can still be tracked individually.
.config/btop/themes/*
!.config/btop/themes/aged-brass.theme
