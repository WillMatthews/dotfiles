# Aged Brass — warm dark btop theme
# Tobacco-brown background, cream text, golden-yellow accents (#FFC332).
# Functional roles tuned to the sage / amber / terracotta family so the
# warm character stays intact instead of jumping to the usual green/red.

# Main background — warm dark brown
theme[main_bg]="#2A211B"

# Main text — cream
theme[main_fg]="#EFE3CE"

# Title color for boxes & toggle-button labels — softer brass.
# Deliberately dimmer than hi_fg so the highlighted shortcut letter
# (drawn in hi_fg) pops out of its label, e.g. the "c" in per-[c]ore.
theme[title]="#C99A3A"

# Keyboard-shortcut highlight — bright signature gold.
# Must stay brighter/more saturated than `title` to be legible.
theme[hi_fg]="#FFC332"

# Background of selected items — bg_alt
theme[selected_bg]="#3A2E25"

# Foreground of selected items — gold accent
theme[selected_fg]="#FFC332"

# Inactive/disabled text AND the unfilled track of meter bars.
# Keep this well darker than the gradient fills (sage/amber/cream) or
# empty bars read as nearly-full light grey and contrast collapses.
theme[inactive_fg]="#5C4A37"

# Text on top of graphs (uptime, net scaling) — cream
theme[graph_text]="#EFE3CE"

# Misc colors in processes box (mini cpu graphs, detail mem graph) — dim gold
theme[proc_misc]="#D6A12A"

# Box outlines — warm border
theme[cpu_box]="#4E3F32"
theme[mem_box]="#4E3F32"
theme[net_box]="#4E3F32"
theme[proc_box]="#4E3F32"

# Dividers
theme[div_line]="#4E3F32"

# Temperature: sage → amber → terracotta
theme[temp_start]="#8FA672"
theme[temp_mid]="#E9994A"
theme[temp_end]="#D26653"

# CPU load: sage → amber → terracotta
theme[cpu_start]="#8FA672"
theme[cpu_mid]="#E9994A"
theme[cpu_end]="#D26653"

# Memory/disk free: low (bad) → high (good)
theme[free_start]="#D26653"
theme[free_mid]="#E9994A"
theme[free_end]="#8FA672"

# Cached: dim cream → dim gold → gold
theme[cached_start]="#A89880"
theme[cached_mid]="#D6A12A"
theme[cached_end]="#FFC332"

# Available: low (bad) → high (good)
theme[available_start]="#D26653"
theme[available_mid]="#E9994A"
theme[available_end]="#8FA672"

# Used: low → high (more used = warmer)
theme[used_start]="#8FA672"
theme[used_mid]="#E9994A"
theme[used_end]="#D26653"

# Download: sage → dim gold → gold
theme[download_start]="#8FA672"
theme[download_mid]="#D6A12A"
theme[download_end]="#FFC332"

# Upload: gold → amber → terracotta
theme[upload_start]="#FFC332"
theme[upload_mid]="#E9994A"
theme[upload_end]="#D26653"

# Process gradient (threads/mem/cpu in process list)
theme[process_start]="#8FA672"
theme[process_mid]="#E9994A"
theme[process_end]="#D26653"
