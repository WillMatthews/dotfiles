    "focusBorder": "#FFC332",
    "selection.background": "#FFC33255",

    "editor.background": "#2A211B",
    "editor.foreground": "#EFE3CE",
    "editorLineNumber.foreground": "#6E6256",
    "editorLineNumber.activeForeground": "#FFC332",
    "editorCursor.foreground": "#FFC332",
    "editor.selectionBackground": "#FFC33233",
    "editor.selectionHighlightBackground": "#FFC33222",
    "editor.lineHighlightBackground": "#3A2E25",
    "editor.findMatchBackground": "#D6A12A66",
    "editor.findMatchHighlightBackground": "#FFC33233",
    "editorWidget.background": "#3A2E25",
    "editorBracketMatch.border": "#FFC332",
    "editorIndentGuide.background1": "#4E3F32",
    "editorIndentGuide.activeBackground1": "#6E6256",
    "editorGutter.modifiedBackground": "#E9994A",
