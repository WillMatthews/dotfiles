    "editorGutter.deletedBackground": "#D26653",
    "editorError.foreground": "#D26653",
    "editorWarning.foreground": "#E9994A",
    "editorInfo.foreground": "#6E8AA1",

    "sideBar.background": "#241C17",
    "sideBar.foreground": "#A89880",
    "sideBar.border": "#4E3F32",
    "sideBarTitle.foreground": "#EFE3CE",
    "sideBarSectionHeader.background": "#2A211B",
    "sideBarSectionHeader.foreground": "#EFE3CE",

    "activityBar.background": "#1F1813",
    "activityBar.foreground": "#FFC332",
    "activityBar.inactiveForeground": "#A89880",
    "activityBar.border": "#4E3F32",
    "activityBarBadge.background": "#FFC332",
    "activityBarBadge.foreground": "#2A211B",

    "titleBar.activeBackground": "#1F1813",
    "titleBar.activeForeground": "#EFE3CE",
    "titleBar.inactiveBackground": "#1F1813",
    "titleBar.inactiveForeground": "#A89880",
    "titleBar.border": "#4E3F32",

    "statusBar.background": "#1F1813",
    "statusBar.foreground": "#EFE3CE",
    "statusBar.border": "#4E3F32",
    "statusBar.noFolderBackground": "#1F1813",
    "statusBar.debuggingBackground": "#E9994A",
    "statusBar.debuggingForeground": "#2A211B",
    "statusBarItem.remoteBackground": "#FFC332",
    "statusBarItem.remoteForeground": "#2A211B",

    "tab.activeBackground": "#2A211B",
    "tab.activeForeground": "#FFC332",
    "tab.activeBorderTop": "#FFC332",
    "tab.inactiveBackground": "#1F1813",
    "tab.inactiveForeground": "#A89880",
    "tab.border": "#4E3F32",
    "editorGroupHeader.tabsBackground": "#1F1813",

    "panel.background": "#2A211B",
    "panel.border": "#4E3F32",
    "panelTitle.activeForeground": "#FFC332",
    "panelTitle.inactiveForeground": "#A89880",

    "button.background": "#FFC332",
    "button.foreground": "#2A211B",
    "button.hoverBackground": "#D6A12A",

    "input.background": "#3A2E25",
    "input.foreground": "#EFE3CE",
    "input.border": "#4E3F32",
    "inputOption.activeBorder": "#FFC332",
    "dropdown.background": "#3A2E25",
    "dropdown.foreground": "#EFE3CE",
    "dropdown.border": "#4E3F32",

    "badge.background": "#FFC332",
    "badge.foreground": "#2A211B",
    "progressBar.background": "#FFC332",

    "list.activeSelectionBackground": "#3A2E25",
    "list.activeSelectionForeground": "#FFC332",
    "list.inactiveSelectionBackground": "#3A2E25",
    "list.hoverBackground": "#3A2E2580",
    "list.highlightForeground": "#FFC332",
    "list.focusBackground": "#3A2E25",

    "scrollbarSlider.background": "#4E3F3299",
    "scrollbarSlider.hoverBackground": "#6E6256AA",
    "scrollbarSlider.activeBackground": "#FFC33288",
    "minimap.findMatchHighlight": "#FFC332",

    "gitDecoration.modifiedResourceForeground": "#E9994A",
    "gitDecoration.untrackedResourceForeground": "#8FA672",
    "gitDecoration.deletedResourceForeground": "#D26653",
    "gitDecoration.ignoredResourceForeground": "#6E6256",

    "terminal.background": "#2A211B",
    "terminal.foreground": "#EFE3CE",
    "terminalCursor.foreground": "#FFC332",
    "terminal.ansiBlack": "#2A211B",
    "terminal.ansiRed": "#A53C2C",
    "terminal.ansiGreen": "#5A7548",
    "terminal.ansiYellow": "#C66B1B",
    "terminal.ansiBlue": "#6E8AA1",
    "terminal.ansiMagenta": "#D6A12A",
    "terminal.ansiCyan": "#A89880",
    "terminal.ansiWhite": "#EFE3CE",
    "terminal.ansiBrightBlack": "#4E3F32",
    "terminal.ansiBrightRed": "#D26653",
    "terminal.ansiBrightGreen": "#8FA672",
    "terminal.ansiBrightYellow": "#E9994A",
    "terminal.ansiBrightBlue": "#9FB4C6",
    "terminal.ansiBrightMagenta": "#FFC332",
    "terminal.ansiBrightCyan": "#C4B69C",
    "terminal.ansiBrightWhite": "#F6EEDB"
