  "editor.tokenColorCustomizations": {
    "comments": "#A89880",
    "keywords": "#E9994A",
    "strings": "#8FA672",
    "numbers": "#D6A12A",
    "functions": "#FFC332",
    "variables": "#EFE3CE",
    "types": "#C4B69C",
    "textMateRules": [
      { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#A89880", "fontStyle": "italic" } },
      { "scope": ["string", "string.quoted", "constant.character"], "settings": { "foreground": "#8FA672" } },
      { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#D6A12A" } },
      { "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"], "settings": { "foreground": "#E9994A" } },
      { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#FFC332" } },
      { "scope": ["entity.name.type", "support.type", "support.class", "entity.name.class"], "settings": { "foreground": "#C4B69C" } },
      { "scope": ["variable", "variable.other", "meta.definition.variable"], "settings": { "foreground": "#EFE3CE" } },
      { "scope": ["entity.name.tag"], "settings": { "foreground": "#E9994A" } },
      { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#D6A12A" } },
      { "scope": ["punctuation", "meta.brace"], "settings": { "foreground": "#A89880" } }
    ]
  }
}
