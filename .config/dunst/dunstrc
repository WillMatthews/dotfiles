# dunst — notification daemon
# Palette: Aged Brass (see ~/Documents/THEMES.md).
# Reminder: you also have xfce4-notifyd installed. Only one daemon can own
# org.freedesktop.Notifications at a time. If notifications look wrong, check
# which is running with: `busctl --user list | grep -i notif`.

[global]
    monitor              = 0
    follow               = mouse

    width                = 320
    height               = (0, 200)
    origin               = top-right
    offset               = (16, 16)
    scale                = 0
    notification_limit   = 6

    progress_bar         = true
    progress_bar_height  = 8
    progress_bar_frame_width = 1
    progress_bar_min_width   = 150
    progress_bar_max_width   = 300

    indicate_hidden      = yes
    transparency         = 0
    separator_height     = 2
    padding              = 10
    horizontal_padding   = 12
    text_icon_padding    = 0
    frame_width          = 1
    frame_color          = "#4E3F32"
    gap_size             = 4
    separator_color      = frame
    sort                 = yes

    font                 = JetBrains Mono 10
    line_height          = 0
    markup               = full
    format               = "<b>%s</b>\n%b"
    alignment            = left
    vertical_alignment   = center
    show_age_threshold   = 60
    ellipsize            = middle
    ignore_newline       = no
    stack_duplicates     = true
    hide_duplicate_count = false
    show_indicators      = yes

    icon_position        = left
    min_icon_size        = 24
    max_icon_size        = 48
    icon_path            = /usr/share/icons/Adwaita/48x48/status/:/usr/share/icons/Adwaita/48x48/devices/

    sticky_history       = yes
    history_length       = 100

    dmenu                = /usr/bin/rofi -dmenu -p dunst
    browser              = /usr/bin/xdg-open

    always_run_script    = true
    title                = Dunst
    class                = Dunst
    corner_radius        = 6
    ignore_dbusclose     = false

    # Wayland / X11 — dunst auto-detects, but explicit doesn't hurt.
    force_xwayland       = false
    force_xinerama       = false

    mouse_left_click     = close_current
    mouse_middle_click   = do_action, close_current
    mouse_right_click    = close_all

[urgency_low]
    background = "#2A211B"
    foreground = "#A89880"
    frame_color = "#3A2E25"
    timeout    = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#2A211B"
    foreground = "#EFE3CE"
    frame_color = "#FFC332"
    timeout    = 8
    default_icon = dialog-information

[urgency_critical]
    background = "#3A2E25"
    foreground = "#EFE3CE"
    frame_color = "#D26653"
    timeout    = 0
    default_icon = dialog-warning
