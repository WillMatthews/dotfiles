# Sway config — ported from ~/.config/i3/config
# Reference: man 5 sway

set $mod Mod4
set $term kitty
set $menu rofi -show drun

font pango:JetBrainsMono Nerd Font Mono 10

default_border pixel 3
default_floating_border pixel 3

# Gaps — sway-only; smart_gaps drops them when only one window is on a workspace.
gaps inner 8
gaps outer 4
smart_gaps on

# Aged Brass theme (see ~/Documents/THEMES.md). Order: border bg text indicator child_border
client.focused          #FFC332 #3A2E25 #EFE3CE #FFC332 #FFC332
client.focused_inactive #4E3F32 #2A211B #A89880 #4E3F32 #4E3F32
client.unfocused        #4E3F32 #2A211B #A89880 #4E3F32 #4E3F32
client.urgent           #D26653 #D26653 #EFE3CE #D26653 #D26653
client.placeholder      #4E3F32 #2A211B #A89880 #4E3F32 #4E3F32

# Vignette wallpaper — bg_alt (#3A2E25) centre fading to a deeper brown at the edges.
output * bg ~/Pictures/wallpapers/aged-brass-vignette.png fill

# Display layout — captured from wdisplays. Re-run `swaymsg -t get_outputs` and update if changed.
# HDMI monitor identified by make/model/serial so the rule survives a cable/port swap.
output eDP-2 mode 2560x1600@300Hz position 3150 107 scale 1.3
output "Microstep MAG 274QRFW CC2HM54A00885" mode 2560x1440@144Hz position 5120 0 scale 1.0

# Keyboard — sway ignores /etc/default/keyboard, so set the UK layout explicitly.
input "type:keyboard" {
    xkb_layout gb
}

# Make sure portals and GUI apps see the Wayland environment
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# XDG autostart
exec dex --autostart --environment sway

# Idle / lock — replaces xss-lock + i3lock from the i3 config
exec swayidle -w \
    timeout 600  'swaylock -f' \
    timeout 900  'swaymsg "output * power off"' \
        resume   'swaymsg "output * power on"' \
    before-sleep 'swaylock -f'

# Network applet (shows up in the bar's tray)
exec nm-applet --indicator

# Keyboard backlight — golden yellow (daily driver, see ~/Documents/COLOUR.md)
exec /home/wam/.local/bin/ite8291r3-ctl monocolor --rgb 255,195,50 -b 35

# Volume / brightness keys — wpctl is wireplumber's native CLI (installed with pipewire).
# -l 1.0 caps volume at 100% so we don't accidentally boost into clipping territory.
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@   5%+ -l 1.0
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@   5%-
bindsym XF86AudioMute        exec wpctl set-mute   @DEFAULT_AUDIO_SINK@   toggle
bindsym XF86AudioMicMute     exec wpctl set-mute   @DEFAULT_AUDIO_SOURCE@ toggle
# -d intel_backlight is host-specific (grindstation / Medion Erazer 16 X1):
# hybrid Intel+Nvidia exposes a stub `nvidia_0` backlight alongside the real
# `intel_backlight`, and brightnessctl's default can land on the stub.
# On a non-hybrid laptop, drop the -d flag (or change the device name to match
# `brightnessctl --list` output for that host).
bindsym XF86MonBrightnessUp   exec brightnessctl -d intel_backlight set +5%
bindsym XF86MonBrightnessDown exec brightnessctl -d intel_backlight set 5%-

# Mouse+$mod to drag floating windows
floating_modifier $mod

# Terminal
bindsym $mod+Return exec $term

# Kill focused window
bindsym $mod+Shift+q kill

# Launchers (rofi runs under XWayland — works fine)
bindsym $mod+d exec $menu
bindsym $mod+Tab exec rofi -show window
bindsym $mod+Shift+d exec rofi -show run
bindsym $mod+space exec rofi -show drun -show-icons

# Screenshots — region to clipboard, region to file, full screen to file
bindsym Print            exec flameshot gui
bindsym Shift+Print      exec grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png
bindsym Ctrl+Print       exec grim ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png

# Focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right
bindsym $mod+Left  focus left
bindsym $mod+Down  focus down
bindsym $mod+Up    focus up
bindsym $mod+Right focus right

# Move
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right
bindsym $mod+Shift+Left  move left
bindsym $mod+Shift+Down  move down
bindsym $mod+Shift+Up    move up
bindsym $mod+Shift+Right move right

# Split / fullscreen / layout
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+grave focus mode_toggle

# Focus parent
bindsym $mod+a focus parent

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
set $ws11 "11"
set $ws12 "12"
set $ws13 "13"
set $ws14 "14"
set $ws15 "15"
set $ws16 "16"
set $ws17 "17"
set $ws18 "18"
set $ws19 "19"
set $ws20 "20"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# switch to workspaces 11-20 (Ctrl+number → 10+number; 0 → 20)
bindsym $mod+Ctrl+1 workspace number $ws11
bindsym $mod+Ctrl+2 workspace number $ws12
bindsym $mod+Ctrl+3 workspace number $ws13
bindsym $mod+Ctrl+4 workspace number $ws14
bindsym $mod+Ctrl+5 workspace number $ws15
bindsym $mod+Ctrl+6 workspace number $ws16
bindsym $mod+Ctrl+7 workspace number $ws17
bindsym $mod+Ctrl+8 workspace number $ws18
bindsym $mod+Ctrl+9 workspace number $ws19
bindsym $mod+Ctrl+0 workspace number $ws20

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# move focused container to workspaces 11-20 (Ctrl+Shift+number → 10+number; 0 → 20)
bindsym $mod+Ctrl+Shift+1 move container to workspace number $ws11
bindsym $mod+Ctrl+Shift+2 move container to workspace number $ws12
bindsym $mod+Ctrl+Shift+3 move container to workspace number $ws13
bindsym $mod+Ctrl+Shift+4 move container to workspace number $ws14
bindsym $mod+Ctrl+Shift+5 move container to workspace number $ws15
bindsym $mod+Ctrl+Shift+6 move container to workspace number $ws16
bindsym $mod+Ctrl+Shift+7 move container to workspace number $ws17
bindsym $mod+Ctrl+Shift+8 move container to workspace number $ws18
bindsym $mod+Ctrl+Shift+9 move container to workspace number $ws19
bindsym $mod+Ctrl+Shift+0 move container to workspace number $ws20

# Reload / restart / exit
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes, exit' 'swaymsg exit'

# Lock / suspend — swayidle's before-sleep handler also locks on suspend
bindsym $mod+Escape  exec swaylock -f
bindsym $mod+Shift+s exec systemctl suspend

# Resize mode
mode "resize" {
    bindsym j         resize shrink width  10 px or 10 ppt
    bindsym k         resize grow   height 10 px or 10 ppt
    bindsym l         resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow   width  10 px or 10 ppt

    bindsym Left  resize shrink width  10 px or 10 ppt
    bindsym Down  resize grow   height 10 px or 10 ppt
    bindsym Up    resize shrink height 10 px or 10 ppt
    bindsym Right resize grow   width  10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# Bar — waybar (GTK, themed in ~/.config/waybar/). No swaybar `bar {}` block is
# defined, so sway leaves the screen edge free and waybar owns the bottom.
# exec_always re-launches waybar on `swaymsg reload`.
exec_always "pkill -x waybar; waybar"

# Include drop-ins (per-host overrides, future tweaks)
include /etc/sway/config.d/*
